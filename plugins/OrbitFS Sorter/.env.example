# Port the sorter listens on.
SORTER_PORT=4055

# Shared auth key. Usually match HIVE_API_KEY from orbitfs-mcp/.env so the
# panel can talk to both services with the same bearer token.
HIVE_API_KEY=

# Path to the Hive root this sorter should scan and move files inside.
# Usually match HIVE_ROOT from orbitfs-mcp/.env, but keep it local here so
# this service can be pointed somewhere else if needed.
SORTER_HIVE_ROOT=C:\Project FireStorm\The Master Hive

# Relative folders inside the Hive root.
SORTER_FOLDER=_sorter
TRASH_FOLDER=_trash
SORTER_INDEX_PATH=_system/Index/folder_index.json

# Safe defaults for the sorter workflow.
SORTER_SAFE_MODE_DEFAULT=true
SORTER_DANGEROUS_MODE_DEFAULT=false
